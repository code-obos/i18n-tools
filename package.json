{
  "name": "@code-obos/i18n-tools",
  "version": "2.0.1",
  "description": "Tools to work with I18N messages",
  "type": "module",
  "keywords": [
    "I18N",
    "bundler",
    "tool",
    "compiler",
    "intl"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/code-obos/i18n-tools"
  },
  "main": "./lib/index.js",
  "bin": {
    "i18n-tool": "i18n-tool"
  },
  "files": [
    "lib"
  ],
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "scripts": {
    "changeset": "changeset",
    "changeset:version": "changeset version",
    "changeset:release": "npm run build && changeset publish",
    "prepare": "husky install",
    "commit": "git-cz",
    "test": "vitest --coverage",
    "test-local": "node lib/index.js build example/messages example/compiled -f formatjs --ast --lut --strict --typescript --timeZone Europe/Oslo",
    "build": "rm -rf lib && tsc -p ."
  },
  "author": "Nicklas Utgaard",
  "license": "MIT",
  "peerDependencies": {
    "@formatjs/intl": "^4.1.12"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@formatjs/intl": "^4.1.12",
    "@types/node": "^24.12.4",
    "@vitest/coverage-v8": "^4.1.8",
    "commitizen": "^4.3.0",
    "cz-conventional-changelog": "^3.3.0",
    "husky": "^8.0.3",
    "lint-staged": "^13.2.2",
    "memfs": "^4.57.3",
    "prettier": "^3.8.3",
    "ts-node": "^10.9.1",
    "typescript": "^5.6.3",
    "vitest": "^4.1.8"
  },
  "dependencies": {
    "@formatjs/cli-lib": "^8.6.0",
    "@formatjs/icu-messageformat-parser": "^3.5.0",
    "chokidar": "^4.0.3",
    "commander": "^14.0.2"
  },
  "lint-staged": {
    "*.{ts,js,css,md}": "prettier --write"
  },
  "config": {
    "commitizen": {
      "path": "node_modules/cz-conventional-changelog"
    }
  }
}
